{
  "name": "ft-docs",
  "version": "5.0.5",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:static": "npx tsx qa/static/check-component-contract.ts",
    "check:runtime": "npx playwright test qa/checks/structural-contract.spec.ts qa/checks/semantic-dom.spec.ts qa/checks/layout-integrity.spec.ts qa/checks/token-compliance.spec.ts",
    "check:runtime-contract": "npx playwright test qa/checks/structural-contract.spec.ts qa/checks/semantic-dom.spec.ts",
    "check:runtime-layout": "npx playwright test qa/checks/layout-integrity.spec.ts",
    "check:runtime-visual": "QA_VISUAL=true npx playwright test qa/checks/visual-regression.spec.ts",
    "check:runtime-tokens": "npx playwright test qa/checks/token-compliance.spec.ts",
    "check:runtime-update-baselines": "QA_VISUAL=true npx playwright test qa/checks/visual-regression.spec.ts --update-snapshots",
    "check:code-extraction": "tsx qa/static/check-code-extraction.ts",
    "check:all": "npm run check:static && npm run check:runtime"
  },
  "dependencies": {
    "@babel/standalone": "^7.28.5",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-switch": "^1.2.5",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.511.0",
    "next": "^16.0.10",
    "next-themes": "^0.4.6",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0",
    "react-live": "^4.1.8",
    "shiki": "^3.15.0",
    "tailwind-merge": "^2.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/babel__standalone": "^7.1.9",
    "@types/node": "^20",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.2.0",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
